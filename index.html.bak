<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>شركة مشاري بندر بن جلوي للمحاماة والاستشارات القانونية</title>
    <meta name="description" content="شركة مشاري بندر بن جلوي للمحاماة والاستشارات القانونية والتوثيق - خدمات قانونية احترافية في جدة وعنيزة">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        /* ─── VARIABLES ─────────────────────────────────────────── */
        :root {
            --navy:        #1B2C6B;
            --navy-dark:   #111d4a;
            --navy-mid:    #223580;
            --gold:        #B8935A;
            --gold-light:  #d4aa72;
            --gold-pale:   #f5ede0;
            --white:       #ffffff;
            --off-white:   #f8f6f2;
            --gray-light:  #f1f0ed;
            --gray:        #6b7280;
            --gray-dark:   #374151;
            --border:      #e5e1d9;
        }

        /* ─── RESET ─────────────────────────────────────────────── */
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; font-size: 16px; }
        body {
            font-family: 'Cairo', sans-serif;
            color: var(--gray-dark);
            background: var(--white);
            overflow-x: hidden;
            line-height: 1.6;
        }
        body.lang-en { font-family: 'Inter', sans-serif; }
        img { max-width: 100%; display: block; }
        a { text-decoration: none; }

        /* ─── UTILITIES ─────────────────────────────────────────── */
        .container { max-width: 1200px; margin: 0 auto; padding: 0 5%; }
        .section-pad { padding: 90px 5%; }

        .tag {
            display: inline-block;
            background: var(--gold-pale);
            color: var(--gold);
            border: 1px solid var(--gold-light);
            padding: 4px 16px;
            border-radius: 20px;
            font-size: .8rem;
            font-weight: 700;
            letter-spacing: .03em;
        }
        .section-title {
            font-size: clamp(1.6rem, 3vw, 2.4rem);
            font-weight: 900;
            color: var(--navy);
            margin: 12px 0 6px;
            line-height: 1.25;
        }
        .gold-bar {
            width: 50px; height: 3px;
            background: linear-gradient(90deg, var(--gold), var(--gold-light));
            border-radius: 2px;
        }
        .section-desc {
            color: var(--gray);
            font-size: 1rem;
            max-width: 580px;
            line-height: 1.85;
        }
        .section-header {
            text-align: center;
            margin-bottom: 55px;
        }
        .section-header .gold-bar { margin: 12px auto 18px; }

        /* ─── NAVBAR ─────────────────────────────────────────────── */
        .navbar {
            position: fixed; inset: 0 0 auto 0;
            z-index: 1000;
            height: 72px;
            background: rgba(17, 29, 74, .96);
            backdrop-filter: blur(12px);
            border-bottom: 2px solid rgba(184,147,90,.45);
            display: flex; align-items: center;
            padding: 0 5%;
            transition: height .3s, background .3s;
        }
        .navbar.scrolled { height: 60px; background: rgba(17,29,74,.99); }

        .nav-inner {
            width: 100%; display: flex;
            align-items: center; justify-content: space-between; gap: 20px;
        }

        /* Logo */
        .nav-logo { display: flex; align-items: center; gap: 11px; }
        .nav-logo-svg { width: 46px; height: 46px; flex-shrink: 0; }
        .nav-logo-text { display: flex; flex-direction: column; }
        .nav-firm-name {
            font-size: .95rem; font-weight: 800;
            color: var(--gold-light); line-height: 1.2;
        }
        .nav-firm-sub {
            font-size: .65rem; color: rgba(255,255,255,.55);
        }

        /* Nav links */
        .nav-links {
            display: flex; align-items: center; gap: 28px;
            list-style: none; flex: 1; justify-content: center;
        }
        .nav-links a {
            color: rgba(255,255,255,.82);
            font-size: .875rem; font-weight: 600;
            transition: color .2s;
            position: relative; padding-bottom: 2px;
        }
        .nav-links a::after {
            content: ''; position: absolute; bottom: -2px; right: 0; left: 0;
            height: 2px; background: var(--gold);
            transform: scaleX(0); transform-origin: right;
            transition: transform .25s;
        }
        [dir="ltr"] .nav-links a::after { transform-origin: left; }
        .nav-links a:hover { color: var(--gold-light); }
        .nav-links a:hover::after { transform: scaleX(1); }

        /* Right controls */
        .nav-controls { display: flex; align-items: center; gap: 12px; }
        .lang-btn {
            background: transparent;
            border: 1.5px solid var(--gold);
            color: var(--gold); padding: 5px 14px;
            border-radius: 20px; cursor: pointer;
            font-size: .8rem; font-family: inherit; font-weight: 700;
            transition: all .2s;
        }
        .lang-btn:hover { background: var(--gold); color: var(--navy); }
        .nav-cta {
            background: var(--gold); color: var(--white);
            padding: 8px 20px; border-radius: 25px;
            font-size: .85rem; font-weight: 800;
            transition: all .25s; white-space: nowrap;
        }
        .nav-cta:hover {
            background: var(--gold-light);
            box-shadow: 0 6px 20px rgba(184,147,90,.4);
        }
        .hamburger {
            display: none; flex-direction: column;
            gap: 5px; cursor: pointer; padding: 5px;
        }
        .hamburger span {
            display: block; width: 24px; height: 2px;
            background: white; border-radius: 2px; transition: all .3s;
        }

        /* Mobile drawer */
        .mobile-drawer {
            position: fixed; top: 72px; inset-inline: 0;
            background: var(--navy-dark);
            border-top: 1px solid rgba(184,147,90,.25);
            padding: 24px 5%; z-index: 999;
            transform: translateY(-8px); opacity: 0;
            visibility: hidden; transition: all .3s;
        }
        .mobile-drawer.open {
            transform: translateY(0); opacity: 1; visibility: visible;
        }
        .mobile-drawer ul { list-style: none; }
        .mobile-drawer li { border-bottom: 1px solid rgba(255,255,255,.07); }
        .mobile-drawer a {
            display: block; padding: 12px 0;
            color: rgba(255,255,255,.85); font-size: .95rem; font-weight: 600;
        }

        /* ─── HERO ───────────────────────────────────────────────── */
        .hero {
            min-height: 100vh;
            background: url('office.jpg') center/cover no-repeat;
            position: relative; overflow: hidden;
            display: flex; align-items: center;
            padding: 90px 5% 60px;
        }
        /* dark navy overlay for watermark effect */
        .hero::before {
            content: '';
            position: absolute; inset: 0;
            background: rgba(17, 29, 74, 0.88);
            background-image: radial-gradient(rgba(184,147,90,.05) 1px, transparent 1px);
            background-size: 40px 40px;
        }
        /* gold diagonal shape */
        .hero-shape {
            position: absolute; inset: 0;
            background: linear-gradient(145deg, transparent 55%, rgba(184,147,90,.12) 100%);
            pointer-events: none;
        }
        /* floating circles */
        .hero-circle {
            position: absolute; border-radius: 50%;
            border: 1px solid rgba(184,147,90,.12);
        }
        .hero-circle-1 { width: 500px; height: 500px; top: -150px; left: -150px; }
        .hero-circle-2 { width: 350px; height: 350px; bottom: -100px; right: -100px; }

        .hero-content {
            position: relative; z-index: 2;
            max-width: 650px;
        }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(184,147,90,.18);
            border: 1px solid rgba(184,147,90,.5);
            color: var(--gold-light);
            padding: 6px 18px; border-radius: 30px;
            font-size: .82rem; font-weight: 700;
            margin-bottom: 28px;
            animation: fadeDown .7s ease both;
        }
        .hero h1 {
            font-size: clamp(2rem, 4vw, 3.3rem);
            font-weight: 900; color: white;
            line-height: 1.28; margin-bottom: 10px;
            animation: fadeDown .8s .1s ease both;
        }
        .hero h1 span { color: var(--gold-light); }
        .hero-sub {
            font-size: 1.1rem; color: rgba(255,255,255,.75);
            margin-bottom: 20px;
            animation: fadeDown .8s .2s ease both;
        }
        .hero-desc {
            font-size: .95rem; color: rgba(255,255,255,.58);
            line-height: 1.9; margin-bottom: 38px;
            animation: fadeDown .8s .3s ease both;
        }
        .hero-btns {
            display: flex; gap: 14px; flex-wrap: wrap;
            animation: fadeDown .8s .4s ease both;
        }
        .btn-gold {
            background: var(--gold); color: var(--white);
            padding: 13px 32px; border-radius: 30px;
            font-weight: 800; font-size: .95rem;
            transition: all .3s;
        }
        .btn-gold:hover {
            background: var(--gold-light);
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(184,147,90,.45);
        }
        .btn-outline {
            background: transparent; color: white;
            padding: 13px 32px; border-radius: 30px;
            font-weight: 700; font-size: .95rem;
            border: 2px solid rgba(255,255,255,.35);
            transition: all .3s;
        }
        .btn-outline:hover {
            border-color: white; background: rgba(255,255,255,.1);
        }

        /* Hero stats */
        .hero-stats {
            position: absolute; bottom: 50px; left: 5%; right: auto;
            display: flex; gap: 50px; z-index: 2;
            animation: fadeUp .9s .5s ease both;
        }
        [dir="ltr"] .hero-stats { left: auto; right: 5%; }
        .hero-stat .num {
            font-size: 2.2rem; font-weight: 900;
            color: var(--gold-light); line-height: 1;
        }
        .hero-stat .lbl {
            font-size: .78rem; color: rgba(255,255,255,.6); margin-top: 3px;
        }

        /* scroll indicator */
        .scroll-hint {
            position: absolute; bottom: 30px;
            left: 50%; transform: translateX(-50%);
            color: rgba(255,255,255,.3); font-size: .75rem;
            display: flex; flex-direction: column; align-items: center; gap: 6px;
            animation: bounce 2s infinite;
        }
        .scroll-hint .arr { font-size: 1.2rem; }

        /* ─── ABOUT ──────────────────────────────────────────────── */
        .about { background: var(--off-white); }
        .about-grid {
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 65px; align-items: center;
        }
        .about-visual {
            position: relative;
        }
        .about-card {
            background: url('office.jpg') center/cover no-repeat;
            border-radius: 24px; height: 440px;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center; gap: 18px;
            position: relative; overflow: hidden;
        }
        /* navy overlay فوق صورة المكتب */
        .about-card::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(145deg, rgba(17,29,74,0.58) 0%, rgba(27,44,107,0.65) 100%);
            background-image: radial-gradient(rgba(184,147,90,.07) 1px, transparent 1px);
            background-size: 30px 30px;
        }
        .about-card-logo { position: relative; z-index: 1; opacity: 1; width: 200px; height: 200px; object-fit: contain; }
        .about-card p {
            color: rgba(255,255,255,.35); font-size: .85rem; position: relative; z-index: 1;
        }
        /* floating badge */
        .about-badge {
            position: absolute; bottom: -18px; left: -18px;
            background: var(--gold); color: var(--white);
            width: 110px; height: 110px; border-radius: 50%;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            font-weight: 900;
            box-shadow: 0 10px 30px rgba(184,147,90,.45);
            z-index: 3; cursor: default;
            transition: transform .35s cubic-bezier(.34,1.56,.64,1), box-shadow .35s;
        }
        .about-badge:hover {
            transform: scale(1.08) rotate(-4deg);
            box-shadow: 0 18px 40px rgba(184,147,90,.55);
        }
        .about-badge .n { font-size: 1.9rem; line-height: 1; }
        .about-badge .t { font-size: .65rem; text-align: center; line-height: 1.3; }

        .about-text .tag { margin-bottom: 14px; }
        .about-text h2 {
            font-size: clamp(1.5rem, 2.8vw, 2.1rem);
            font-weight: 900; color: var(--navy); margin-bottom: 2px;
            white-space: nowrap; line-height: 1.2;
        }
        .about-h2-sub {
            font-size: clamp(0.95rem, 1.8vw, 1.25rem);
            font-weight: 700; color: var(--gold);
            margin-bottom: 14px; line-height: 1.4;
        }
        @media (max-width: 700px) {
            .about-text h2 { white-space: normal; font-size: 1.45rem; }
        }
        .about-text .gold-bar { margin-bottom: 20px; }
        .about-text p {
            color: var(--gray); line-height: 1.95;
            margin-bottom: 14px; font-size: .95rem;
        }
        .offices {
            display: flex; gap: 14px; flex-wrap: wrap; margin-top: 26px;
        }
        .office-pill {
            display: flex; align-items: center; gap: 10px;
            background: white; border: 1px solid var(--border);
            border-radius: 14px; padding: 12px 18px;
            box-shadow: 0 2px 10px rgba(0,0,0,.05);
        }
        .office-pill-icon {
            width: 34px; height: 34px;
            background: var(--gold-pale); border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; flex-shrink: 0;
        }
        .office-city { font-weight: 800; color: var(--navy); font-size: .9rem; }
        .office-addr { font-size: .75rem; color: var(--gray); }

        /* ─── SERVICES ───────────────────────────────────────────── */
        .services { background: white; }
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 22px;
        }
        .service-card {
            background: var(--off-white);
            border: 1px solid var(--border);
            border-radius: 18px; padding: 28px 24px;
            transition: all .3s; position: relative;
            overflow: hidden; cursor: default;
        }
        .service-card::after {
            content: ''; position: absolute;
            bottom: 0; left: 0; right: 0; height: 3px;
            background: linear-gradient(90deg, var(--gold), var(--gold-light));
            transform: scaleX(0); transform-origin: right;
            transition: transform .3s;
        }
        [dir="ltr"] .service-card::after { transform-origin: left; }
        .service-card:hover {
            border-color: rgba(184,147,90,.4);
            transform: translateY(-5px);
            box-shadow: 0 16px 40px rgba(27,44,107,.09);
            background: white;
        }
        .service-card:hover::after { transform: scaleX(1); }
        .svc-icon {
            width: 52px; height: 52px;
            background: linear-gradient(135deg, var(--navy), var(--navy-mid));
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; margin-bottom: 16px;
        }
        .service-card h3 {
            font-size: .95rem; font-weight: 800;
            color: var(--navy); margin-bottom: 8px;
        }
        .service-card p {
            font-size: .82rem; color: var(--gray); line-height: 1.75;
        }

        /* ─── LITIGATION (dark bg) ───────────────────────────────── */
        .litigation {
            background: var(--navy);
            position: relative; overflow: hidden;
        }
        .litigation::before {
            content: ''; position: absolute; inset: 0;
            background-image: radial-gradient(rgba(184,147,90,.05) 1px, transparent 1px);
            background-size: 35px 35px;
        }
        .litigation .section-title { color: white; }
        .litigation .tag {
            background: rgba(184,147,90,.18);
            border-color: rgba(184,147,90,.45);
        }
        .litigation .section-desc { color: rgba(255,255,255,.6); margin: 0 auto; }
        .litigation .gold-bar { margin: 12px auto 18px; }

        .lit-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
            gap: 13px; position: relative; z-index: 1;
        }
        .lit-tag {
            background: rgba(255,255,255,.05);
            border: 1px solid rgba(184,147,90,.25);
            color: rgba(255,255,255,.88);
            padding: 14px 18px; border-radius: 12px;
            font-size: .88rem; font-weight: 700;
            text-align: center; transition: all .3s; cursor: default;
        }
        .lit-tag:hover {
            background: var(--gold); color: var(--navy);
            border-color: var(--gold); transform: translateY(-3px);
        }

        /* ─── VISION / MISSION / VALUES ─────────────────────────── */
        .vmv { background: var(--off-white); }
        .vmv-grid {
            display: grid; grid-template-columns: repeat(3,1fr); gap: 26px;
        }
        .vmv-card {
            background: white; border-radius: 22px;
            padding: 38px 30px;
            border: 1px solid var(--border);
            transition: all .3s; position: relative; overflow: hidden;
        }
        .vmv-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 50px rgba(27,44,107,.1);
            border-color: rgba(184,147,90,.4);
        }
        .vmv-icon {
            width: 58px; height: 58px;
            background: linear-gradient(135deg, var(--navy), var(--navy-mid));
            border-radius: 16px; font-size: 1.5rem;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 18px;
        }
        .vmv-card h3 {
            font-size: 1.25rem; font-weight: 900;
            color: var(--navy); margin-bottom: 4px;
        }
        .vmv-card .gold-bar { margin-bottom: 14px; }
        .vmv-card p {
            color: var(--gray); font-size: .88rem; line-height: 1.95;
        }
        .vals { display: flex; flex-direction: column; gap: 10px; margin-top: 4px; }
        .val-row {
            display: flex; align-items: flex-start; gap: 12px;
            background: var(--off-white); border-radius: 10px; padding: 11px 14px;
            transition: transform .3s cubic-bezier(.34,1.56,.64,1), box-shadow .3s;
        }
        .val-row:hover {
            transform: translateX(-4px);
            box-shadow: 0 6px 16px rgba(27,44,107,.08);
        }
        .val-dot {
            width: 9px; height: 9px; background: var(--gold);
            border-radius: 50%; flex-shrink: 0; margin-top: 5px;
        }
        .val-row strong { color: var(--navy); font-size: .85rem; display: block; margin-bottom: 2px; }
        .val-row span { color: var(--gray); font-size: .78rem; }

        /* ─── GOALS (أهدافنا) ────────────────────────────────────── */
        .goals { background: white; }
        .goals-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
            gap: 22px;
        }
        .goal-card {
            border: 1px solid var(--border);
            border-radius: 18px; padding: 30px 24px;
            transition: all .3s;
        }
        .goal-card:hover {
            border-color: var(--gold-light);
            background: var(--gold-pale);
            transform: translateY(-4px);
        }
        .goal-num {
            font-size: 2.5rem; font-weight: 900;
            color: rgba(184,147,90,.2); line-height: 1;
            margin-bottom: 10px;
        }
        .goal-card h3 { font-size: .95rem; font-weight: 800; color: var(--navy); margin-bottom: 8px; }
        .goal-card p { font-size: .82rem; color: var(--gray); line-height: 1.75; }

        /* ─── WHY US ─────────────────────────────────────────────── */
        .why { background: var(--navy); position: relative; overflow: hidden; }
        .why::before {
            content: ''; position: absolute; inset: 0;
            background-image: radial-gradient(rgba(184,147,90,.05) 1px, transparent 1px);
            background-size: 35px 35px;
        }
        .why .section-title { color: white; }
        .why .tag { background: rgba(184,147,90,.18); border-color: rgba(184,147,90,.45); }
        .why .gold-bar { margin: 12px auto 18px; }
        .why-grid {
            display: grid; grid-template-columns: repeat(3,1fr);
            gap: 24px; position: relative; z-index: 1;
        }
        .why-card {
            background: rgba(255,255,255,.05);
            border: 1px solid rgba(184,147,90,.2);
            border-radius: 20px; padding: 36px 28px;
            text-align: center; transition: all .3s;
        }
        .why-card:hover {
            background: rgba(255,255,255,.09);
            border-color: rgba(184,147,90,.5);
            transform: translateY(-5px);
        }
        .why-icon {
            width: 68px; height: 68px;
            background: linear-gradient(135deg, rgba(184,147,90,.25), rgba(184,147,90,.1));
            border: 1px solid rgba(184,147,90,.3);
            border-radius: 20px; font-size: 1.8rem;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 20px;
        }
        .why-card h3 { font-size: 1rem; font-weight: 800; color: white; margin-bottom: 10px; }
        .why-card p { font-size: .83rem; color: rgba(255,255,255,.6); line-height: 1.8; }

        /* ─── PACKAGES ───────────────────────────────────────────── */
        .packages { background: var(--off-white); }
        .pkg-wrapper {
            background: white; border: 1px solid var(--border);
            border-radius: 28px; overflow: hidden;
            box-shadow: 0 20px 60px rgba(27,44,107,.07);
            max-width: 900px; margin: 0 auto;
        }
        .pkg-header {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-dark) 100%);
            padding: 36px 40px; position: relative; overflow: hidden;
        }
        .pkg-header::before {
            content: ''; position: absolute; inset: 0;
            background-image: radial-gradient(rgba(184,147,90,.07) 1px, transparent 1px);
            background-size: 25px 25px;
        }
        .pkg-header h3 {
            position: relative; z-index: 1;
            color: var(--gold-light); font-size: 1.4rem; font-weight: 900;
            margin-bottom: 8px;
        }
        .pkg-header p {
            position: relative; z-index: 1;
            color: rgba(255,255,255,.6); font-size: .88rem;
        }
        .pkg-body { padding: 36px 40px; }
        .pkg-features {
            display: grid; grid-template-columns: repeat(2,1fr);
            gap: 13px; margin-bottom: 28px;
        }
        .pkg-feat {
            display: flex; align-items: center; gap: 10px;
            background: var(--off-white); border-radius: 10px; padding: 13px 16px;
            transition: transform .3s cubic-bezier(.34,1.56,.64,1), box-shadow .3s, background .3s;
        }
        .pkg-feat:hover {
            transform: translateX(-4px) scale(1.02);
            background: white; box-shadow: 0 6px 20px rgba(27,44,107,.08);
        }
        .pkg-feat .ck { color: var(--gold); font-size: 1rem; flex-shrink: 0; font-weight: 900; }
        .pkg-feat span { font-size: .86rem; color: var(--gray-dark); font-weight: 600; }
        .pkg-note {
            text-align: center; font-size: .83rem;
            color: var(--gray); line-height: 1.8; margin-bottom: 22px;
        }
        .pkg-chips {
            display: flex; gap: 10px; flex-wrap: wrap; justify-content: center;
        }
        .pkg-chip {
            background: var(--gold); color: var(--white);
            padding: 7px 18px; border-radius: 20px;
            font-size: .82rem; font-weight: 800;
            transition: transform .3s cubic-bezier(.34,1.56,.64,1), box-shadow .3s;
            cursor: default;
        }
        .pkg-chip:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 8px 20px rgba(184,147,90,.4);
        }
        .pkg-cta {
            text-align: center; margin-top: 28px;
        }

        /* ─── STATS ──────────────────────────────────────────────── */
        .stats { background: white; }
        .stats-grid {
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 70px; align-items: center;
        }
        .chart-wrap {
            display: flex; justify-content: center; align-items: center;
        }
        #caseChart {
            max-width: 340px; width: 100%;
            transform: perspective(600px) rotateX(28deg) scale(1.05);
            filter: drop-shadow(0 28px 24px rgba(27,44,107,0.45));
            transition: transform .4s;
        }
        #caseChart:hover {
            transform: perspective(600px) rotateX(12deg) scale(1.08);
        }
        .stats-list { display: flex; flex-direction: column; gap: 14px; }
        .stat-row {
            display: flex; align-items: center; gap: 12px;
            transition: transform .3s cubic-bezier(.34,1.56,.64,1);
        }
        .stat-row:hover { transform: translateX(-5px); }
        .stat-dot {
            width: 13px; height: 13px; border-radius: 4px; flex-shrink: 0;
        }
        .stat-info { flex: 1; }
        .stat-lbl {
            font-size: .82rem; font-weight: 700; color: var(--navy); margin-bottom: 4px;
        }
        .bar-track {
            height: 7px; background: var(--gray-light);
            border-radius: 4px; overflow: hidden;
        }
        .bar-fill { height: 100%; border-radius: 4px; transition: width 1s ease; }
        .stat-pct {
            font-size: .82rem; font-weight: 800;
            color: var(--navy); min-width: 42px; text-align: end;
        }

        /* ─── ACCREDITATIONS ─────────────────────────────────────── */
        .accred { background: var(--off-white); }
        .accred-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
            gap: 16px;
        }
        .accred-item {
            background: white; border: 1px solid var(--border);
            border-radius: 14px; padding: 18px 14px;
            min-height: 90px;
            display: flex; align-items: center; justify-content: center;
            text-align: center;
            transition: transform .35s cubic-bezier(.34,1.56,.64,1), box-shadow .35s, border-color .3s;
            cursor: pointer;
        }
        .accred-item:hover {
            border-color: var(--gold-light);
            box-shadow: 0 12px 32px rgba(184,147,90,.18);
            transform: translateY(-6px) scale(1.04) rotate(-1deg);
        }
        .accred-item img {
            max-width: 130px; max-height: 60px;
            width: 100%; height: auto; object-fit: contain;
            filter: grayscale(30%); transition: filter .3s;
        }
        .accred-item:hover img { filter: grayscale(0%); }
        .accred-item span {
            font-size: .8rem; font-weight: 700; color: var(--navy); line-height: 1.45;
        }

        /* ─── CONTACT ────────────────────────────────────────────── */
        .contact { background: var(--navy); position: relative; overflow: hidden; }
        .contact::before {
            content: ''; position: absolute; inset: 0;
            background-image: radial-gradient(rgba(184,147,90,.05) 1px, transparent 1px);
            background-size: 35px 35px;
        }
        .contact .section-title { color: white; }
        .contact .tag { background: rgba(184,147,90,.18); border-color: rgba(184,147,90,.45); }
        .contact .gold-bar { margin: 12px auto 18px; }

        .contact-grid {
            display: grid; grid-template-columns: 1fr 1.4fr;
            gap: 60px; position: relative; z-index: 1;
        }
        .contact-info h3 {
            color: var(--gold-light); font-size: 1.1rem;
            font-weight: 800; margin-bottom: 28px;
        }
        .ci-list { display: flex; flex-direction: column; gap: 18px; }
        .ci-row { display: flex; align-items: center; gap: 14px; }
        .ci-ico {
            width: 44px; height: 44px;
            background: rgba(184,147,90,.18); border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; flex-shrink: 0;
        }
        .ci-lbl { font-size: .75rem; color: rgba(255,255,255,.45); margin-bottom: 2px; }
        .ci-val { font-size: .9rem; color: white; font-weight: 700; }
        .social-section { margin-top: 32px; }
        .social-section h4 { color: rgba(255,255,255,.5); font-size: .8rem; margin-bottom: 12px; }
        .social-row { display: flex; gap: 10px; }
        .soc-btn {
            width: 40px; height: 40px;
            border: 1px solid rgba(184,147,90,.35); border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: var(--gold-light); font-size: .9rem;
            transition: all .3s; font-weight: 700;
        }
        .soc-btn:hover { background: var(--gold); color: var(--navy); border-color: var(--gold); }

        /* Form */
        .contact-form {
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(184,147,90,.2);
            border-radius: 24px; padding: 38px;
        }
        .contact-form h3 {
            color: white; font-size: 1.1rem; font-weight: 800; margin-bottom: 24px;
        }
        .form-group { margin-bottom: 18px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .form-group label {
            display: block; color: rgba(255,255,255,.6);
            font-size: .8rem; margin-bottom: 7px; font-weight: 600;
        }
        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            background: rgba(255,255,255,.07);
            border: 1px solid rgba(184,147,90,.25);
            border-radius: 10px; padding: 11px 14px;
            color: white; font-family: inherit; font-size: .88rem;
            outline: none; transition: border-color .3s;
        }
        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus { border-color: var(--gold); }
        .form-group input::placeholder,
        .form-group textarea::placeholder { color: rgba(255,255,255,.25); }
        .form-group select option { background: var(--navy-dark); color: white; }
        .form-group textarea { height: 115px; resize: vertical; }
        .submit-btn {
            width: 100%; background: var(--gold); color: var(--navy);
            border: none; padding: 13px; border-radius: 30px;
            font-size: .95rem; font-weight: 900;
            cursor: pointer; font-family: inherit; transition: all .3s;
        }
        .submit-btn:hover {
            background: var(--gold-light); transform: translateY(-2px);
        }

        /* ─── FOOTER ─────────────────────────────────────────────── */
        footer {
            background: var(--navy-dark);
            padding: 40px 5% 22px;
        }
        .footer-top {
            display: flex; justify-content: space-between;
            align-items: center; flex-wrap: wrap; gap: 20px;
            padding-bottom: 28px;
            border-bottom: 1px solid rgba(184,147,90,.2);
            margin-bottom: 22px;
        }
        .footer-logo { display: flex; align-items: center; gap: 12px; }
        .footer-name { color: var(--gold-light); font-size: .9rem; font-weight: 800; }
        .footer-sub { color: rgba(255,255,255,.4); font-size: .7rem; }
        .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
        .footer-links a {
            color: rgba(255,255,255,.55); font-size: .82rem;
            transition: color .2s;
        }
        .footer-links a:hover { color: var(--gold-light); }
        .footer-social { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
        .footer-top { flex-wrap: wrap; gap: 20px; }
        .footer-bottom {
            text-align: center; font-size: .78rem; color: rgba(255,255,255,.35);
        }

        /* ─── FLOATING BUTTONS ───────────────────────────────────── */
        .whatsapp-fab {
            position: fixed; bottom: 28px; right: 28px;
            width: 56px; height: 56px;
            background: #25D366; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem; color: white; z-index: 999;
            box-shadow: 0 6px 20px rgba(37,211,102,.5);
            transition: all .3s;
        }
        [dir="rtl"] .whatsapp-fab { right: 28px; left: auto; }
        [dir="ltr"] .whatsapp-fab { right: 28px; }
        .whatsapp-fab:hover { transform: scale(1.1); }

        .scroll-fab {
            position: fixed; bottom: 28px; left: 28px;
            width: 44px; height: 44px;
            background: var(--gold); color: var(--navy);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; font-weight: 900;
            z-index: 999; cursor: pointer;
            box-shadow: 0 4px 16px rgba(184,147,90,.45);
            opacity: 0; visibility: hidden; transition: all .3s;
        }
        .scroll-fab.show { opacity: 1; visibility: visible; }
        .scroll-fab:hover { background: var(--gold-light); }

        /* ─── ANIMATIONS ─────────────────────────────────────────── */
        @keyframes fadeDown {
            from { opacity: 0; transform: translateY(-20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes bounce {
            0%,100% { transform: translateX(-50%) translateY(0); }
            50%      { transform: translateX(-50%) translateY(8px); }
        }
        .fade-up {
            opacity: 0; transform: translateY(28px);
            transition: opacity .65s ease, transform .65s ease;
        }
        .fade-up.in { opacity: 1; transform: translateY(0); }

        /* ─── RESPONSIVE ─────────────────────────────────────────── */
        @media (max-width: 900px) {
            .nav-links { display: none; }
            .hamburger { display: flex; }
            .about-grid,
            .stats-grid,
            .contact-grid { grid-template-columns: 1fr; }
            .vmv-grid,
            .why-grid { grid-template-columns: 1fr 1fr; }
            .hero-stats { position: static; margin-top: 40px; }
            .scroll-hint { display: none; }
        }
        @media (max-width: 600px) {
            .vmv-grid,
            .why-grid { grid-template-columns: 1fr; }
            .pkg-features { grid-template-columns: 1fr; }
            .form-row { grid-template-columns: 1fr; }
            .footer-top { flex-direction: column; text-align: center; }
            .footer-links { justify-content: center; }
            .lit-grid { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
</head>
<body>

<!-- ═══════════════════════════════════ NAVBAR ═══════ -->
<nav class="navbar" id="navbar">
