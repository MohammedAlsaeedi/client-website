<!-- ═══════════════════════════════════ HERO ═══════════ -->
<section class="hero" id="home">
    <div class="hero-shape"></div>
    <div class="hero-circle hero-circle-1"></div>
    <div class="hero-circle hero-circle-2"></div>

    <div class="hero-content">
        <div class="hero-badge">
            <span>⚖</span>
            <span data-key="heroBadge">شركة سعودية مرخصة · محاماة واستشارات قانونية</span>
        </div>

        <h1>
            <span data-key="heroH1a">شركة</span>
            <span> </span>
            <span class="gold-span" data-key="heroH1b">مشاري بندر بن جلوي</span>
        </h1>
        <div class="hero-sub" data-key="heroSub">للمحاماة والاستشارات القانونية والتوثيق</div>
        <p class="hero-desc" data-key="heroDesc">
            نقدم خدمات قانونية متكاملة بخبرة عالية ورؤية حديثة تستند إلى مبادئ العدالة والمهنية والالتزام.
            نخدم الأفراد والشركات والجهات الحكومية في جدة وعنيزة وعلى مستوى المملكة.
        </p>
        <div class="hero-btns">
            <a href="https://wa.me/966533532153" target="_blank" rel="noopener" class="btn-gold" data-key="heroCta1">احجز استشارة مجانية</a>
            <a href="#services" class="btn-outline" data-key="heroCta2">تعرف على خدماتنا</a>
        </div>
    </div>

    <div class="hero-stats">
        <div class="hero-stat">
            <div class="num">+500</div>
            <div class="lbl" data-key="stat1">قضية منجزة</div>
        </div>
        <div class="hero-stat">
            <div class="num">+10</div>
            <div class="lbl" data-key="stat2">سنوات خبرة</div>
        </div>
        <div class="hero-stat">
            <div class="num">2</div>
            <div class="lbl" data-key="stat3">فروع</div>
        </div>
    </div>

    <div class="scroll-hint">
        <span>استكشف</span>
        <span class="arr">↓</span>
    </div>
</section>

<!-- ═══════════════════════════════════ ABOUT ══════════ -->
<section class="about section-pad" id="about">
    <div class="about-grid fade-up">
        <!-- Visual -->
        <div class="about-visual">
            <div class="about-card">
                <img class="about-card-logo" src="logo.png" alt="شعار شركة مشاري بندر بن جلوي">
            </div>
            <div class="about-badge">
                <div class="n">+10</div>
                <div class="t" data-key="aboutBadge">سنوات<br>خبرة</div>
            </div>
        </div>

        <!-- Text -->
        <div class="about-text">
            <div class="tag" data-key="aboutTag">من نحن</div>
            <h2 data-key="aboutH2a">شركة مشاري بندر بن جلوي</h2>
            <p class="about-h2-sub" data-key="aboutH2b">للمحاماة والاستشارات القانونية</p>
            <div class="gold-bar"></div>
            <p data-key="aboutP1">
                شركة مهنية سعودية مرخصة تقدم خدماتها القانونية بخبرة عالية ورؤية حديثة تستند إلى مبادئ العدالة والمهنية والالتزام. نتميز بفريق قانوني متخصص يضم نخبة من المحامين والمستشارين ذوي الكفاءة العالية.
            </p>
            <p data-key="aboutP2">
                نقدم خدماتنا للأفراد والجهات الحكومية والقطاع الخاص، ونسعى إلى تقديم حلول قانونية متكاملة ومبتكرة بمعايير مهنية رفيعة المستوى.
            </p>
            <div class="offices">
                <div class="office-pill">
                    <div class="office-pill-icon">📍</div>
                    <div>
                        <div class="office-city" data-key="city1">جدة</div>
                        <div class="office-addr" data-key="addr1">طريق الملك عبدالعزيز</div>
                    </div>
                </div>
                <div class="office-pill">
                    <div class="office-pill-icon">📍</div>
                    <div>
                        <div class="office-city" data-key="city2">عنيزة</div>
                        <div class="office-addr" data-key="addr2">طريق الأمير سلطان</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══════════════════════════════════ SERVICES ════════ -->
<section class="services section-pad" id="services">
    <div class="section-header fade-up">
        <div class="tag" data-key="svcTag">ما نقدمه</div>
        <h2 class="section-title" data-key="svcTitle">خدماتنا القانونية</h2>
        <div class="gold-bar"></div>
    </div>
    <div class="services-grid fade-up">
        <div class="service-card">
            <div class="svc-icon">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="9" y1="15" x2="13" y2="15"/><path d="M15 2v4h4" stroke="white" stroke-width="1.5" fill="none"/></svg>
            </div>
