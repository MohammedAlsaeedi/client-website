                <span></span><span></span><span></span>
            </div>
        </div>
    </div>
</nav>

<!-- Mobile drawer -->
<div class="mobile-drawer" id="drawer">
    <ul>
        <li><a href="#about"      onclick="toggleMenu()" data-key="navAbout">من نحن</a></li>
        <li><a href="#services"   onclick="toggleMenu()" data-key="navServices">خدماتنا</a></li>
