// ─── LANGUAGE TOGGLE ─────────────────────────────────────────
let lang = 0; // 0=AR 1=EN
function toggleLang() {
    lang = lang === 0 ? 1 : 0;
    const html = document.documentElement;
    const isEn = lang === 1;

    html.lang = isEn ? 'en' : 'ar';
    html.dir  = isEn ? 'ltr' : 'rtl';
    document.getElementById('langBtn').textContent = isEn ? 'ع' : 'EN';
    document.body.classList.toggle('lang-en', isEn);

    document.querySelectorAll('[data-key]').forEach(el => {
        const key = el.dataset.key;
        if (!T[key]) return;
        const val = T[key][lang];
        if (val === undefined) return;

        if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
            // handled separately
        } else {
            el.textContent = val;
        }
    });

    // Placeholders
    document.querySelectorAll('[data-ph-ar]').forEach(el => {
        el.placeholder = isEn ? el.dataset.phEn : el.dataset.phAr;
    });

    // Page title
    document.title = isEn
        ? 'Meshari Bandar Bin Jalawi Law Firm'
        : 'شركة مشاري بندر بن جلوي للمحاماة والاستشارات القانونية';

    // Hero h1 needs span preserved
    const h1 = document.querySelector('.hero h1');
    if (h1) {
        h1.innerHTML = `<span data-key="heroH1a">${T.heroH1a[lang]}</span> <span class="gold-span" data-key="heroH1b">${T.heroH1b[lang]}</span>`;
        h1.style.color = 'white';
        h1.querySelector('.gold-span').style.color = 'var(--gold-light)';
    }

    drawChart();
}

// Init placeholders
document.querySelectorAll('[data-ph-ar]').forEach(el => {
    el.placeholder = el.dataset.phAr;
});

// ─── NAVBAR SCROLL ───────────────────────────────────────────
window.addEventListener('scroll', () => {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 70);
    document.getElementById('scrollFab').classList.toggle('show', window.scrollY > 400);
});

// ─── MOBILE MENU ─────────────────────────────────────────────
function toggleMenu() {
    document.getElementById('drawer').classList.toggle('open');
}

// ─── SCROLL TOP ──────────────────────────────────────────────
function scrollToTop() { window.scrollTo({ top: 0, behavior: 'smooth' }); }

// ─── INTERSECTION OBSERVER ───────────────────────────────────
const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
}, { threshold: 0.1 });
document.querySelectorAll('.fade-up').forEach(el => obs.observe(el));

// ─── DONUT CHART ─────────────────────────────────────────────
function drawChart() {
    const canvas = document.getElementById('caseChart');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    const data   = [26.3, 21.1, 13.2, 10.5, 7.9, 7.9, 7.9, 5.3];
    const labelsAr = ['تجاري','جنائي','تنفيذ','لجان','شخصية','عمالي','إداري','أوقاف'];
    const labelsEn = ['Commercial','Criminal','Execution','Committees','Personal','Labor','Admin','Endow.'];
    const labels = lang === 0 ? labelsAr : labelsEn;
    const colors = ['#1B2C6B','#B8935A','#2d4a8a','#d4aa72','#6b82b8','#8a7050','#4a5568','#9ca3af'];

    const total = data.reduce((a,b) => a+b, 0);
    const cx = canvas.width/2, cy = canvas.height/2;
    const outerR = Math.min(cx,cy) - 15;
    const innerR = outerR * 0.52;

    let startAngle = -Math.PI/2;
    data.forEach((val, i) => {
        const slice = (val/total)*2*Math.PI;
        ctx.beginPath();
        ctx.moveTo(cx,cy);
        ctx.arc(cx, cy, outerR, startAngle, startAngle+slice);
        ctx.closePath();
        ctx.fillStyle = colors[i];
        ctx.fill();
        ctx.strokeStyle = '#ffffff';
        ctx.lineWidth = 2.5;
        ctx.stroke();
        startAngle += slice;
    });

    // inner hole
    ctx.beginPath();
    ctx.arc(cx, cy, innerR, 0, 2*Math.PI);
    ctx.fillStyle = '#ffffff';
    ctx.fill();

    // center text
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = '#1B2C6B';
    ctx.font = `bold 22px Cairo, Inter, sans-serif`;
    ctx.fillText('+500', cx, cy-11);
    ctx.font = `14px Cairo, Inter, sans-serif`;
    ctx.fillStyle = '#6b7280';
    ctx.fillText(lang===0?'قضية':'cases', cx, cy+12);
}

window.addEventListener('load', drawChart);

// ─── FORM ────────────────────────────────────────────────────
function handleForm(e) {
    e.preventDefault();
    const btn = e.target.querySelector('.submit-btn');
    const orig = btn.textContent;
    btn.textContent = lang===0 ? '✓ تم الإرسال بنجاح!' : '✓ Message Sent!';
    btn.style.background = '#22c55e';
    setTimeout(() => {
        btn.textContent = orig;
        btn.style.background = '';
        e.target.reset();
    }, 3000);
}
</script>
</body>
</html>
